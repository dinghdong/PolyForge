# Copy to .env.local and fill in. .env.local is gitignored.

# --- Sepolia keys (testnet only — never reuse real keys) ---
# The "user" smart account (headless demo). Holds Sepolia USDC for bets+fees.
SPIKE_USER_PK=0x...
# Star agent / backend operator. Pays operator gas (recordBet, mints, deploys).
SPIKE_AGENT_A_PK=0x...
# Follower agent (A2A copy rail).
SPIKE_AGENT_B_PK=0x...

# --- Contracts (written automatically by the deploy scripts) ---
MARKET_ADDRESS=0x...        # npm run deploy:market
AGENT_NFA_ADDRESS=0x...     # npm run deploy:nfa

# --- Optional ---
# Venice AI (OpenAI-compatible). Absent/unfunded → deterministic fallback engine.
VENICE_API_KEY=
# Override the pinned Sepolia RPC if you prefer your own endpoint.
# SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
# Public webhook URL for relayer status events (else a cloudflared quick tunnel is auto-started).
# WEBHOOK_PUBLIC_URL=
# Set WEBHOOK_TUNNEL=0 in production to skip cloudflared. On Render the service's
# own RENDER_EXTERNAL_URL is used automatically as the webhook target.
# WEBHOOK_TUNNEL=0
